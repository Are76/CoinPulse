# CoinPulse local development environment
#
# Local development can use a local PostgreSQL database.
# Vercel/production MUST use a hosted PostgreSQL URL configured in Vercel Environment Variables.
# Never commit real production secrets to this file.
#
# PULSECHAIN_RPC_URL uses a localhost placeholder for generic validation.
# Replace it with a real PulseChain RPC endpoint only when intentionally testing live RPC behavior.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coinpulse
REDIS_URL=redis://localhost:6379
PULSECHAIN_RPC_URL=http://localhost:8545

# Example hosted PostgreSQL format for Vercel, Neon, Supabase, Railway, etc.:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Optional: blocks per RPC fetch window. Conservative default (2) works with public PulseChain RPC.
# Increase for private/dedicated RPC nodes (e.g. 500 or 2000) for faster historical syncs.
# SYNC_MAX_WINDOW_SIZE=2
