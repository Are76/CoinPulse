generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SyncRunStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
}

enum SyncTrigger {
  MANUAL
  IMPORT
  REBUILD
}

enum LedgerEntryType {
  RECEIVE
  SEND
  SWAP_IN
  SWAP_OUT
  FEE
  LP_ADD_IN
  LP_ADD_OUT
  LP_REMOVE_IN
  LP_REMOVE_OUT
  STAKE_START
  STAKE_END
  STAKE_PRINCIPAL_LOCKED
  STAKE_PRINCIPAL_RETURNED
  STAKE_YIELD_RECEIVED
  STAKE_PENALTY
  STAKE_LOCK
  STAKE_UNLOCK
  STAKE_REWARD
  INTERNAL_TRANSFER
  APPROVAL_IGNORE
}

enum RawRecordStatus {
  ACTIVE
  REORGED
}

enum SourceFamily {
  TRANSFERS
  DEX
  LP
  STAKING
  NATIVE
  HEXMINING
}

enum TokenMetadataSourceKind {
  SEED
  RPC
  MANUAL
}

enum PriceSourceType {
  ONCHAIN_POOL
  ONCHAIN_ROUTE
  ORACLE
  MANUAL
  DEXSCREENER
}

enum MaterializationStatus {
  RUNNING
  FAILED
  COMPLETED
}

model Chain {
  id                Int                 @id
  slug              String              @unique
  name              String
  rpcUrl            String
  nativeAssetId     String              @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  wallets           Wallet[]
  tokens            Token[]
  syncRuns          SyncRun[]
  syncCursors       SyncCursor[]
  rawBlocks         RawBlock[]
  rawTransactions   RawTransaction[]
  rawLogs           RawLog[]
  rawTokenTransfers RawTokenTransfer[]
  rawDexSwaps       RawDexSwap[]
  rawLpActions      RawLpAction[]
  rawStakeActions   RawStakeAction[]
  ledgerActionGroups LedgerActionGroup[]
  ledgerEntries     LedgerEntry[]
  portfolioTokenBalances PortfolioTokenBalance[]
  portfolioLpPositions PortfolioLpPosition[]
  portfolioStakePositions PortfolioStakePosition[]
  portfolioMaterializationStates PortfolioMaterializationState[]
  priceObservations               PriceObservation[]
  protocols                       Protocol[]
  rpcRequestLogs                  RpcRequestLog[]
  reorgEvents                     ReorgEvent[]
  rawHexDailyDataObservations     RawHexDailyDataObservation[]
  rawEndedHexStakeObservations    RawEndedHexStakeObservation[]
  hexStakeListSnapshots           HexStakeListSnapshot[]
}

model Wallet {
  id                 String              @id @default(cuid())
  chainId            Int
  address            String
  addressLower       String
  label              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  chain              Chain               @relation(fields: [chainId], references: [id], onDelete: Restrict)
  syncRuns           SyncRun[]
  syncCursors        SyncCursor[]
  ledgerActionGroups LedgerActionGroup[]
  ledgerEntries      LedgerEntry[]
  portfolioTokenBalances PortfolioTokenBalance[]
  portfolioLpPositions PortfolioLpPosition[]
  portfolioStakePositions PortfolioStakePosition[]
  portfolioMaterializationStates PortfolioMaterializationState[]

  @@unique([chainId, addressLower])
  @@index([chainId, addressLower])
}

model Token {
  id               String                 @id @default(cuid())
  chainId          Int
  address          String
  addressLower     String
  assetId          String                 @unique
  symbol           String?
  name             String?
  decimals         Int
  decimalsSource   String
  isNative         Boolean                @default(false)
  isIgnored        Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  chain            Chain                  @relation(fields: [chainId], references: [id], onDelete: Restrict)
  metadataSources  TokenMetadataSource[]
  assetFlags       AssetFlag[]
  rawTransfers     RawTokenTransfer[]
  ledgerEntries    LedgerEntry[]

  @@unique([chainId, addressLower])
  @@index([chainId, addressLower])
}

model TokenMetadataSource {
  id          String                  @id @default(cuid())
  tokenId      String
  sourceKind   TokenMetadataSourceKind
  sourceRef    String
  decimals     Int
  symbol       String?
  name         String?
  observedAt   DateTime               @default(now())
  createdAt    DateTime               @default(now())
  token        Token                  @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([tokenId, sourceKind, sourceRef])
}

model Protocol {
  id             String   @id @default(cuid())
  chainId         Int
  slug            String
  name            String
  category        String
  safeStartBlock  BigInt?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  chain           Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([chainId, slug])
}

model AssetFlag {
  id          String   @id @default(cuid())
  tokenId      String
  flag         String
  source       String
  createdAt    DateTime @default(now())
  token        Token    @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([tokenId, flag, source])
}

model SyncRun {
  id               String         @id @default(cuid())
  walletId         String?
  chainId          Int
  trigger          SyncTrigger    @default(MANUAL)
  status           SyncRunStatus  @default(PENDING)
  stage            String
  sourceFamilies   SourceFamily[]
  startBlock       BigInt
  endBlock         BigInt?
  latestSafeBlock  BigInt?
  policyLabel      String
  warningCount     Int            @default(0)
  warningDetails   Json?
  errorMessage     String?
  failedSourceFamily SourceFamily?
  failedFromBlock  BigInt?
  failedToBlock    BigInt?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  wallet           Wallet?        @relation(fields: [walletId], references: [id], onDelete: SetNull)
  chain            Chain          @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@index([chainId, createdAt(sort: Desc)])
  @@index([walletId, createdAt(sort: Desc)])
}

model SyncCursor {
  id              String       @id @default(cuid())
  walletId        String
  chainId         Int
  sourceFamily    SourceFamily
  fromBlock       BigInt
  toBlock         BigInt
  blockHash       String?
  updatedAt       DateTime     @updatedAt
  wallet          Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  chain           Chain        @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([walletId, chainId, sourceFamily])
}

model RpcRequestLog {
  id           String   @id @default(cuid())
  chainId      Int
  method       String
  requestKey   String   @unique
  fromBlock    BigInt?
  toBlock      BigInt?
  statusCode   Int?
  errorMessage String?
  requestedAt  DateTime @default(now())
  completedAt  DateTime?
  chain        Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)
}

model ReorgEvent {
  id                 String   @id @default(cuid())
  chainId            Int
  fromBlock          BigInt
  toBlock            BigInt
  canonicalBlockHash String
  observedBlockHash  String
  detectedAt         DateTime @default(now())
  chain              Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)
}

model RawBlock {
  id            String         @id @default(cuid())
  chainId       Int
  blockNumber   BigInt
  blockHash     String
  parentHash    String
  timestamp     DateTime
  status        RawRecordStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  chain         Chain          @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([chainId, blockNumber, blockHash])
  @@index([chainId, blockNumber])
}

model RawTransaction {
  id                String          @id @default(cuid())
  chainId           Int
  txHash            String
  blockNumber       BigInt
  blockHash         String
  transactionIndex  Int
  fromAddress       String
  toAddress         String?
  valueRaw          Decimal         @db.Decimal(78, 0)
  gasPriceRaw       Decimal?        @db.Decimal(78, 0)
  gasUsedRaw        Decimal?        @db.Decimal(78, 0)
  status            RawRecordStatus @default(ACTIVE)
  createdAt         DateTime        @default(now())
  chain             Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)
  rawLogs           RawLog[]

  @@unique([chainId, txHash, blockHash])
  @@index([chainId, txHash])
}

model RawLog {
  id                String          @id @default(cuid())
  chainId           Int
  transactionId     String?
  txHash            String
  blockNumber       BigInt
  blockHash         String
  logIndex          Int
  address           String
  topic0            String?
  topic1            String?
  topic2            String?
  topic3            String?
  data              String
  status            RawRecordStatus @default(ACTIVE)
  createdAt         DateTime        @default(now())
  chain             Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)
  transaction       RawTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([chainId, txHash, logIndex, blockHash])
  @@index([chainId, address, blockNumber])
}

model RawTokenTransfer {
  id                String          @id @default(cuid())
  chainId           Int
  tokenId           String
  tokenAddress      String
  assetIdSnapshot   String
  decimalsSnapshot  Int
  txHash            String
  blockNumber       BigInt
  blockHash         String
  logIndex          Int
  fromAddress       String
  toAddress         String
  amountRaw         Decimal         @db.Decimal(78, 0)
  status            RawRecordStatus @default(ACTIVE)
  createdAt         DateTime        @default(now())
  chain             Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)
  token             Token           @relation(fields: [tokenId], references: [id], onDelete: Restrict)

  @@unique([chainId, txHash, logIndex, blockHash])
  @@index([chainId, tokenId, blockNumber])
  @@index([chainId, assetIdSnapshot, blockNumber])
}

model RawDexSwap {
  id                    String          @id @default(cuid())
  chainId               Int
  protocolSlug          String
  txHash                String
  blockNumber           BigInt
  blockHash             String
  logIndex              Int
  pairAddress           String
  initiatorAddress      String
  counterpartyAddress   String?
  soldTokenAddress      String
  soldAssetIdSnapshot   String
  soldDecimalsSnapshot  Int
  soldAmountRaw         Decimal         @db.Decimal(78, 0)
  boughtTokenAddress    String
  boughtAssetIdSnapshot String
  boughtDecimalsSnapshot Int
  boughtAmountRaw       Decimal         @db.Decimal(78, 0)
  feeAssetIdSnapshot    String
  feeDecimalsSnapshot   Int
  feeAmountRaw          Decimal         @db.Decimal(78, 0)
  status                RawRecordStatus @default(ACTIVE)
  createdAt             DateTime        @default(now())
  chain                 Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([chainId, txHash, logIndex, blockHash])
  @@index([chainId, initiatorAddress, blockNumber])
  @@index([chainId, soldAssetIdSnapshot, blockNumber])
  @@index([chainId, boughtAssetIdSnapshot, blockNumber])
}

model RawLpAction {
  id                    String          @id @default(cuid())
  chainId               Int
  protocolSlug          String
  actionKind            String
  txHash                String
  blockNumber           BigInt
  blockHash             String
  logIndex              Int
  pairAddress           String
  initiatorAddress      String
  counterpartyAddress   String?
  token0Address         String
  token0AssetIdSnapshot String
  token0DecimalsSnapshot Int
  token0AmountRaw       Decimal         @db.Decimal(78, 0)
  token1Address         String
  token1AssetIdSnapshot String
  token1DecimalsSnapshot Int
  token1AmountRaw       Decimal         @db.Decimal(78, 0)
  lpTokenAddress        String
  lpAssetIdSnapshot     String
  lpDecimalsSnapshot    Int
  lpAmountRaw           Decimal         @db.Decimal(78, 0)
  feeAssetIdSnapshot    String
  feeDecimalsSnapshot   Int
  feeAmountRaw          Decimal         @db.Decimal(78, 0)
  status                RawRecordStatus @default(ACTIVE)
  createdAt             DateTime        @default(now())
  chain                 Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([chainId, txHash, logIndex, blockHash])
  @@index([chainId, initiatorAddress, blockNumber])
  @@index([chainId, lpAssetIdSnapshot, blockNumber])
  @@index([chainId, token0AssetIdSnapshot, blockNumber])
  @@index([chainId, token1AssetIdSnapshot, blockNumber])
}

model RawStakeAction {
  id                    String          @id @default(cuid())
  chainId               Int
  protocolSlug          String
  actionKind            String
  txHash                String
  blockNumber           BigInt
  blockHash             String
  actionIndex           Int
  contractAddress       String
  initiatorAddress      String
  stakeId               BigInt?
  stakeIndex            Int?
  stakedDays            Int?
  tokenAddress          String
  assetIdSnapshot       String
  decimalsSnapshot      Int
  principalLockedRaw    Decimal?        @db.Decimal(78, 0)
  totalReturnedRaw      Decimal?        @db.Decimal(78, 0)
  principalReturnedRaw  Decimal?        @db.Decimal(78, 0)
  yieldRaw              Decimal?        @db.Decimal(78, 0)
  penaltyRaw            Decimal?        @db.Decimal(78, 0)
  feeAssetIdSnapshot    String
  feeDecimalsSnapshot   Int
  feeAmountRaw          Decimal         @db.Decimal(78, 0)
  status                RawRecordStatus @default(ACTIVE)
  createdAt             DateTime        @default(now())
  chain                 Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([chainId, txHash, actionKind, actionIndex, blockHash])
  @@index([chainId, initiatorAddress, blockNumber])
  @@index([chainId, stakeId, blockNumber])
  @@index([chainId, assetIdSnapshot, blockNumber])
}

model LedgerActionGroup {
  id                String   @id @default(cuid())
  chainId           Int
  walletId          String
  txHash            String
  actionGroupKey    String
  actionType        String
  blockNumber       BigInt?
  occurredAt        DateTime
  createdAt         DateTime @default(now())
  chain             Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)
  wallet            Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  entries           LedgerEntry[]

  @@unique([chainId, walletId, actionGroupKey])
  @@index([walletId, occurredAt(sort: Desc)])
}

model LedgerEntry {
  id                String            @id @default(cuid())
  chainId           Int
  walletId          String
  actionGroupId     String
  tokenId           String?
  txHash            String
  entryType         LedgerEntryType
  assetId           String
  quantity          Decimal           @db.Decimal(65, 18)
  valueUsd          Decimal?          @db.Decimal(65, 18)
  direction         String
  normalizerVersion String
  occurredAt        DateTime
  sourceLogIndex    Int?
  sourceLogKey      String?
  dedupeKey         String
  createdAt         DateTime          @default(now())
  chain             Chain             @relation(fields: [chainId], references: [id], onDelete: Restrict)
  wallet            Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  actionGroup       LedgerActionGroup @relation(fields: [actionGroupId], references: [id], onDelete: Cascade)
  token             Token?            @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  @@unique([chainId, walletId, dedupeKey])
  @@index([walletId, assetId, occurredAt])
}

model PortfolioTokenBalance {
  id               String   @id @default(cuid())
  walletId         String
  walletAddress    String
  chainId          Int
  assetId          String
  assetAddress     String?
  balanceQuantity  Decimal  @db.Decimal(65, 18)
  decimals         Int?
  updatedFromBlock BigInt?
  updatedToBlock   BigInt?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  wallet           Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  chain            Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([walletId, chainId, assetId])
  @@index([chainId, walletAddress])
}

model PortfolioLpPosition {
  id                 String   @id @default(cuid())
  walletId           String
  walletAddress      String
  chainId            Int
  lpAssetId          String
  lpTokenAddress     String?
  lpTokenQuantity    Decimal  @db.Decimal(65, 18)
  token0AssetId      String?
  token0Address      String?
  token1AssetId      String?
  token1Address      String?
  token0NetQuantity  Decimal? @db.Decimal(65, 18)
  token1NetQuantity  Decimal? @db.Decimal(65, 18)
  updatedFromBlock   BigInt?
  updatedToBlock     BigInt?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  wallet             Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  chain              Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([walletId, chainId, lpAssetId])
  @@index([chainId, walletAddress])
}

model PortfolioStakePosition {
  id            String   @id @default(cuid())
  walletId      String
  walletAddress String
  chainId       Int
  stakeKey      String
  tokenAssetId  String
  tokenAddress  String?
  principalQuantity Decimal  @db.Decimal(65, 18)
  returnedQuantity  Decimal  @db.Decimal(65, 18)
  yieldQuantity     Decimal? @db.Decimal(65, 18)
  penaltyQuantity   Decimal? @db.Decimal(65, 18)
  status        String
  startBlock    BigInt?
  endBlock      BigInt?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  chain         Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([walletId, chainId, stakeKey])
  @@index([chainId, walletAddress])
}

model PortfolioMaterializationState {
  id                    String                @id @default(cuid())
  walletId              String
  chainId               Int
  status                MaterializationStatus
  completedSuccessfully Boolean               @default(false)
  lastAttemptedAt       DateTime
  latestMaterializedAt  DateTime?
  sourceLedgerFromBlock BigInt?
  sourceLedgerToBlock   BigInt?
  updatedFromBlock      BigInt?
  updatedToBlock        BigInt?
  warningCount          Int                   @default(0)
  warningDetails        Json?
  errorMessage          String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  wallet                Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  chain                 Chain                 @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([walletId, chainId])
  @@index([chainId, walletId])
}

model PriceObservation {
  id                String          @id
  chainId           Int
  assetId           String
  assetAddress      String?
  quoteAsset        String
  price             Decimal         @db.Decimal(65, 18)
  sourceType        PriceSourceType
  sourceId          String
  routeMetadata     Json?
  liquidityUsd      Decimal?        @db.Decimal(65, 18)
  confidence        Decimal         @db.Decimal(5, 4)
  observedAt        DateTime
  blockNumber       BigInt?
  staleAfterSeconds Int
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  chain             Chain           @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@index([chainId, assetId, quoteAsset, observedAt(sort: Desc)])
  @@index([chainId, sourceType, observedAt(sort: Desc)])
}

// ─── HexMining Phase 4 — raw dailyDataRange observation models ────────────────
//
// Each RawHexDailyDataObservation row represents one persisted dailyDataRange
// RPC call result. Rows are append-only raw audit evidence — never mutated.
//
// Reorg/invalidation is handled via the companion model below (append-only).
// The raw observation row is never updated for reorg state.
//
// canonicalPayload stores the dailyDataRange response as deterministic JSON
// with all uint*/int* contract values encoded as base-10 decimal strings.
// JavaScript bigint values must never appear directly in the JSON. The
// payloadHash field is the SHA-256 hex of the canonical serialized payload.
//
// Multiple rows may exist for the same (chainId, rangeStartDay, rangeEndDay,
// observedAtBlock) if reads were made from different RPC endpoints or with
// different payloads. Deduplication is enforced at the service layer using
// (chainId, sourceFamily, rangeStartDay, rangeEndDay, observedAtBlock,
// rpcEndpointLabel, payloadHash) before writing. No DB unique constraint is
// applied to preserve legitimate retry/endpoint observations.

model RawHexDailyDataObservation {
  id               String         @id @default(cuid())
  chainId          Int
  sourceFamily     SourceFamily   @default(HEXMINING)
  rangeStartDay    Int
  rangeEndDay      Int
  observedAtBlock  BigInt
  observedAt       DateTime
  rpcEndpointLabel String?
  payloadVersion   String         @default("v1")
  canonicalPayload String
  payloadHash      String
  warnings         String[]       @default([])
  createdAt        DateTime       @default(now())
  chain            Chain          @relation(fields: [chainId], references: [id], onDelete: Restrict)
  invalidations    RawHexDailyDataObservationInvalidation[] @relation("InvalidatedObservation")
  supersessions    RawHexDailyDataObservationInvalidation[] @relation("SupersessionTarget")

  @@index([chainId, rangeStartDay, rangeEndDay, observedAtBlock])
  @@index([chainId, sourceFamily])
  @@index([payloadHash])
}

// Append-only invalidation record. Written when a reorg or supersession event
// makes an existing observation non-canonical. The raw observation row is never
// mutated — this model records the event alongside it.
model RawHexDailyDataObservationInvalidation {
  id                        String                      @id @default(cuid())
  observationId             String
  reason                    String
  reorgBlockHash            String?
  supersededByObservationId String?
  createdAt                 DateTime                    @default(now())
  observation               RawHexDailyDataObservation  @relation("InvalidatedObservation", fields: [observationId], references: [id], onDelete: Restrict)
  supersededBy              RawHexDailyDataObservation? @relation("SupersessionTarget", fields: [supersededByObservationId], references: [id], onDelete: SetNull)

  @@index([observationId])
  @@index([supersededByObservationId])
}

// ─── HexMining Phase 5 — raw ended stake observation model ───────────────────
//
// Each RawEndedHexStakeObservation row represents one persisted discovery of
// an ended HEX stake for a wallet on PulseChain. Rows are append-only raw
// audit evidence — never mutated after write.
//
// discoveryMethod records how the ended stake was found:
//   "raw_stake_action" — found via existing RawStakeAction endStake record
//   "rpc_history"      — found via direct RPC transaction history scan
//
// lockedDay and stakeShares are nullable because they are not available from
// endStake calldata alone. They may be populated if the corresponding
// startStake block snapshot is available or via historical RPC lookup.
//
// yieldHex is the raw yield in hearts (bigint decimal string) from the
// endStake confirmation. Null if the endStake record lacks yieldRaw.
//
// isComplete: false signals that one or more fields could not be recovered
// (e.g., lockedDay or stakeShares is null). The DTO must surface this as a
// warning — never coerce missing fields to zero.
//
// Multiple rows may exist for the same (walletAddress, chainId, stakeId)
// if the stake is re-discovered from a different source or block. The service
// layer enforces deduplication using (chainId, walletAddress, stakeId,
// endBlockNumber, discoveryMethod) before writing.

model RawEndedHexStakeObservation {
  id               String       @id @default(cuid())
  chainId          Int
  sourceFamily     SourceFamily @default(HEXMINING)
  walletAddress    String
  stakeId          String
  stakeIndex       Int?
  stakedDays       Int?
  lockedDay        Int?
  stakeShares      String?
  principalHex     String?
  yieldHex         String?
  penaltyHex       String?
  endTxHash        String
  endBlockNumber   BigInt
  startTxHash      String?
  startBlockNumber BigInt?
  discoveryMethod  String
  observedAt       DateTime
  isComplete       Boolean      @default(false)
  warnings         String[]     @default([])
  createdAt        DateTime     @default(now())
  chain            Chain        @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@index([chainId, walletAddress, stakeId])
  @@index([chainId, walletAddress, endBlockNumber])
  @@index([chainId, sourceFamily])
}

// ─── HexMining stake list snapshot ────────────────────────────────────────────
//
// One row per (walletAddress, chainId). Upserted on each successful RPC read.
// The route checks freshness before hitting the RPC: if ageSeconds ≤
// staleAfterSeconds, the cached DTO is returned directly.
//
// canonicalPayload stores the serialized HexStakeListDto JSON.
// staleAfterSeconds is recorded alongside the payload so the TTL can be
// tightened or relaxed per-row without a schema migration.

model HexStakeListSnapshot {
  id                String   @id @default(cuid())
  walletAddress     String
  chainId           Int
  payloadVersion    String   @default("v1")
  canonicalPayload  String
  observedAt        DateTime
  staleAfterSeconds Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  chain             Chain    @relation(fields: [chainId], references: [id], onDelete: Restrict)

  @@unique([walletAddress, chainId])
  @@index([chainId, walletAddress])
}
